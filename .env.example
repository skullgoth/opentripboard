# Database password (shared across services)
DB_PASSWORD=postgres

# PostgreSQL connection pool
# PG_POOL_MIN=2
# PG_POOL_MAX=20
# PG_POOL_IDLE_TIMEOUT_MS=30000
# PG_POOL_CONNECTION_TIMEOUT_MS=5000

# WebSocket authentication timeout (milliseconds)
# WS_AUTH_TIMEOUT_MS=10000

# Rate limiting — disable entirely
# RATE_LIMIT_DISABLED=true

# Rate limiting — auth routes (login/register)
# RATE_LIMIT_AUTH_MAX=10
# RATE_LIMIT_AUTH_WINDOW=1 minute

# Rate limiting — password routes (change/reset)
# RATE_LIMIT_PASSWORD_MAX=5
# RATE_LIMIT_PASSWORD_WINDOW=15 minutes

# Account lockout after failed login attempts
# ACCOUNT_LOCKOUT_THRESHOLD=5
# ACCOUNT_LOCKOUT_DURATION_MIN=15

# Debug flags
# DEBUG_POOL=true
# DEBUG_RATE_LIMIT=true
